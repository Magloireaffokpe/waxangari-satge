# Base de données PostgreSQL (Neon recommandé)
DATABASE_URL="postgresql://user:password@host:5432/waxangari?sslmode=require"

# NextAuth - générez avec: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="votre-secret-tres-long-et-aleatoire"

# Clé pour créer le premier admin (page /setup)
FIRST_ADMIN_KEY="votre-cle-setup-secrete"

# Stockage des CV: "local" (défaut) ou "vercel-blob"
STORAGE_TYPE="local"

# Uniquement si STORAGE_TYPE=vercel-blob
# BLOB_READ_WRITE_TOKEN="vercel_blob_xxx"
